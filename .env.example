# Flask Configuration
FLASK_ENV=production
SECRET_KEY=change-this-to-a-random-secret-key

# Database (Railway will set DATABASE_URL automatically)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Email Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password
MAIL_DEFAULT_SENDER=noreply@giftexchange.com

# App Settings
APP_NAME=Family Gift Exchange

# WebAuthn / Passkey Configuration
# RP_ID should be your domain without port (e.g., giftexchange.example.com)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Power Family Wishlist
# ORIGIN must include scheme and port if non-standard (e.g., https://giftexchange.example.com)
WEBAUTHN_ORIGIN=http://localhost:5000
